	annote = {Comment: Update: camera-ready; L1 loss is size-averaged; code of partial conv layer: https://github.com/NVIDIA/partialconv. Published at ECCV 2018},
	file = {Liu et al. - 2018 - Image Inpainting for Irregular Holes Using Partial.pdf:/home/simon/Zotero/storage/8EU3Q39H/Liu et al. - 2018 - Image Inpainting for Irregular Holes Using Partial.pdf:application/pdf},
}

