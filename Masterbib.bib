	file = {Varentsov et al. - 2020 - High-Resolution Temperature Mapping by Geostatisti.pdf:/home/simon/Zotero/storage/R532ZWQD/Varentsov et al. - 2020 - High-Resolution Temperature Mapping by Geostatisti.pdf:application/pdf},
}

